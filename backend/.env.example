# AI API Key（二选一）
# 推荐使用 Anthropic Claude（视觉理解更好）
ANTHROPIC_API_KEY=sk-ant-xxxxx

# 或者使用 OpenAI GPT-4o
# OPENAI_API_KEY=sk-xxxxx

# 高德地图 Web 服务 API Key
# 用于地图搜索、地理编码、逆地理编码功能
# 注意：需要在高德开放平台申请 "Web服务" 类型的 Key
# 不是 "Web端(JS API)" 类型，也不是 Android/iOS 类型
AMAP_WEB_SERVICE_KEY=your_amap_web_service_key_here

# 服务端口
PORT=3002
